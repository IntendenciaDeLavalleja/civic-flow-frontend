# -------------------------------------------------------
# Variables públicas del Frontend (Vite) — CivicFlow
#
# Los nombres VITE_* son expuestos al cliente (browser).
# Estos valores se hornean en el bundle en tiempo de build.
#
# En Coolify: configurar como Build Variables antes de desplegar.
# En Docker manual: --build-arg VITE_API_URL=https://...
# -------------------------------------------------------

# URL base del backend Flask, incluyendo el prefijo /api
# Ejemplo producción: https://api.civicflow.ejemplo.uy/api
# Ejemplo local:      (no definir — el proxy de Vite maneja /api automáticamente)
VITE_API_URL=https://api.civicflow.ejemplo.uy/api
